{
  "port": 8080,
  "timeout": "10s",
  "healthCheckInterval": "10s",
  "maxRetries": 3,
  "servers": [
    {
      "url": "localhost:9000",
      "weight": 3
    },
    {
      "url": "localhost:9001"
    },
    {
      "url": "localhost:9002"
    }
  ],
  "rateLimiter": {
    "rate": 200,
    "burstSeconds": 2,
    "expiry": "10s"
  },
  "balancer": "least-connections"
}